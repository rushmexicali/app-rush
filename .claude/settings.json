{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "PowerShell(git status*)",
      "PowerShell(git add*)",
      "PowerShell(git commit*)",
      "PowerShell(git diff*)",
      "PowerShell(git log*)",
      "PowerShell(git show*)",
      "PowerShell(git branch*)",
      "PowerShell(git restore*)",
      "PowerShell(git config*)",
      "PowerShell(curl.exe*)",
      "PowerShell(.\\herramientas\\supabase.exe*)",
      "PowerShell(powershell -ExecutionPolicy Bypass -File .\\scripts\\*)",
      "PowerShell(Get-Content*)",
      "PowerShell(Get-ChildItem*)",
      "PowerShell(Test-Path*)",
      "PowerShell(New-Item -ItemType Directory*)",
      "PowerShell(Get-Command*)",
      "PowerShell(Get-Date*)"
    ],
    "ask": [
      "PowerShell(git reset --hard*)",
      "PowerShell(git rebase*)"
    ],
    "deny": [
      "PowerShell(Remove-Item C:\\Windows*)",
      "PowerShell(Remove-Item C:\\Program Files*)",
      "PowerShell(Format-Volume*)"
    ]
  }
}
