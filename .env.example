# Plantilla de variables de entorno — SIN VALORES.
# Este archivo SI se sube a Git. Sirve para saber que llaves hace falta configurar.
#
# Para usarlo: copia este archivo como ".env" y llena los valores reales ahi.
# El ".env" NUNCA se sube (esta en .gitignore).

# --- Supabase (Paso 1: panel > Project Settings > API) ---
# URL publica del proyecto, algo como https://abcdefgh.supabase.co
SUPABASE_URL=
# Llave publica (sb_publishable_...). Se puede exponer en la app; respeta las reglas RLS.
SUPABASE_PUBLISHABLE_KEY=
# Llave MAESTRA (sb_secret_...). Se salta toda la seguridad. Solo del lado del servidor.
# NUNCA dentro de la app del telefono.
SUPABASE_SECRET_KEY=

# --- Supabase CLI (Fase 2) ---
# Token de cuenta para desplegar Edge Functions desde la terminal.
# Se crea en https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# El identificador del proyecto, visible en la URL del panel.
SUPABASE_PROJECT_REF=

# --- Zettle (Paso 5: https://my.zettle.com/apps/api-keys, scope READ:PURCHASE) ---
# La API key completa (es un JWT largo). Se usa para pedir el access token.
ZETTLE_API_KEY=
# Se saca de adentro de la API key. Lo obtenemos juntos en el Paso 5.
ZETTLE_CLIENT_ID=

# --- Webhook (Paso 6) ---
# URL publica de la Edge Function, algo como
# https://abcdefgh.supabase.co/functions/v1/zettle-webhook
ZETTLE_WEBHOOK_URL=
# Lo devuelve Zettle al crear la suscripcion. Sirve para verificar firmas mas adelante.
ZETTLE_SIGNING_KEY=

# --- Codigo de acceso de la app ---
# Lo teclea el supervisor una vez en el telefono. Tambien va en los
# secretos de Supabase: supabase secrets set CODIGO_ACCESO=...
CODIGO_ACCESO=

# --- Contacto ---
# Correo al que Zettle avisa si el webhook falla.
CONTACTO_EMAIL=
