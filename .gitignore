# === SECRETOS — NUNCA subir a Git ===
# Aqui viven la API key de Zettle y la service_role de Supabase, que mueven pagos.
.env
.env.local
.env.*.local

# Excepcion: la plantilla SIN valores si se sube, para saber que variables hacen falta.
!.env.example

# === Herramientas descargadas (72 MB de binario, se vuelven a bajar) ===
herramientas/

# === Ajustes locales de Claude Code (son de esta maquina, no del proyecto) ===
.claude/settings.local.json

# === Archivos basura de Windows / editores ===
Thumbs.db
desktop.ini
*.swp
.vscode/
.idea/

# === Dependencias y compilados (para cuando llegue la app Flutter) ===
node_modules/
build/
.dart_tool/
*.log

# === Archivos temporales del CLI de Supabase ===
supabase/.temp/
